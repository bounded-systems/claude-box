# launcherd.container — launch-controller daemon (the --launcher and --dispatch doors)
#
# `nix build .#launcherd-image` is real — built, loaded, and smoke-tested
# end-to-end in a real podman container: both sockets come up correctly,
# dispatch.sock structurally cannot reach launch/kill/list/attach
# (UNKNOWN_METHOD), and non-dispatchable rooms are refused.
#
# Reaching the host's rootless podman API socket (the CONTAINER_HOST mount
# below) is RESOLVED and verified live — `podman version`, `podman ps`, and a
# real ephemeral `podman run` all succeed from inside this container. The
# earlier "flat permission denial" this comment described was a MISDIAGNOSIS:
# it was never a socket-permission / SELinux / rootless-in-rootless
# user-namespace problem. keep-id:uid=1000 maps this container's uid 1000 back
# to the VM's invoking user (uid 501), which owns the socket, so the
# connection itself is fine. The actual failure was the podman CLIENT refusing
# to initialize because the image bakes HOME=/root, which is neither writable
# nor present for the uid-1000 process under ReadOnly=true ("cannot resolve
# /root: lstat /root: no such file or directory"). The fix is a writable HOME
# (Environment=HOME=/tmp below, backed by ReadOnlyTmpfs) — a config detail, NOT
# the security-posture decision the old comment warned about. No SELinux
# confinement was disabled; the socket mount keeps its default labeling.
#
# Boxes ask to spawn/inspect/kill sub-boxes through /run/doors/launcherd.sock
# (the --launcher door, attenuated, name-based identity — see LAUNCHERD.md),
# or request an independent task session through /run/doors/dispatch.sock
# (the --dispatch door, doors-blind, allow-listed rooms only — see
# launcherd.ts's DISPATCH_METHODS / handleDispatch). launcherd owns the
# runtime for BOTH lanes; boxes never hold podman.
#
# Install:
#   cp *.volume *.container ~/.config/containers/systemd/
#   systemctl --user daemon-reload
#   systemctl --user enable --now launcherd
#
# Logs:
#   journalctl --user -u launcherd -f

[Unit]
Description=launcherd — launch-controller daemon for claude-box (launch + dispatch)
After=claude-doors-volume.service

[Container]
Image=localhost/launcherd:dev
ContainerName=launcherd

# Same numeric uid/gid as every other socket-creating door daemon — see
# keeperd.container's comment for why (shared doors dir, no world-writable).
# Confirmed live: without this, launcherd's OWN assertSocketDir check
# correctly refuses to start ("refusing socket in world-writable /run/doors
# (hijack risk)") rather than silently trusting a directory anyone can write
# to — this UserNS line is the actual fix, not a reason to relax that check.
UserNS=keep-id:uid=1000,gid=1000

# Socket directory — same shared volume every other door uses. launcherd
# listens on BOTH launcherd.sock (general) and dispatch.sock (narrow) here —
# see launcherd.ts's serve(socketPath, dispatchSocketPath).
Volume=%h/.claude-box/run:/run/doors

# launcherd is the one daemon that must reach the HOST's container runtime
# (to actually spawn/inspect/kill sibling containers) — unlike keeperd/netd/
# scoutd, which are pure socket daemons with no host-control surface at all.
# %t resolves to the VM systemd-user runtime dir (/run/user/501 here — the
# invoking user's uid, NOT 1000), where the rootless podman API socket lives.
# Verified live: launcherd reaches AND successfully uses this socket (spawn
# works) once HOME is writable (see below). This is still a meaningfully more
# privileged grant than anything keeperd/netd/scoutd hold — it is adjacent to
# "control the host's container runtime" — so it stays scoped to this one
# daemon; a narrower proxy in front of the socket remains a reasonable future
# hardening, but is no longer a BLOCKER the way the old comment implied.
Volume=%t/podman/podman.sock:/run/podman/podman.sock
Environment=CONTAINER_HOST=unix:///run/podman/podman.sock

# The launcherd IMAGE bakes HOME=/root (it normally runs as root). Under
# UserNS=keep-id:uid=1000 + ReadOnly=true, /root is neither present nor
# writable for the uid-1000 process, and the podman CLIENT refuses to start
# without a usable HOME ("cannot resolve /root: lstat /root: no such file or
# directory") — which is what made spawns fail, NOT any socket-permission
# issue. Point HOME at the writable tmpfs (ReadOnlyTmpfs gives /tmp) so the
# client can initialize. Verified live: with this, `podman run` from inside
# launcherd succeeds against the mounted host socket.
Environment=HOME=/tmp

# Security hardening — same floor as the other doors. NoNewPrivileges/
# DropCapability=all/ReadOnly still apply to launcherd's OWN process; they do
# NOT reduce what the mounted podman socket itself can do once reached (see
# the note above).
NoNewPrivileges=true
ReadOnly=true
ReadOnlyTmpfs=true
DropCapability=all
SecurityLabelDisable=true

# Resource limits
PidsLimit=256
Memory=512m

[Service]
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
