# launcherd.container — launch-controller daemon (the --launcher and --dispatch doors)
#
# `nix build .#launcherd-image` NOW EXISTS and is real — built, loaded, and
# smoke-tested end-to-end in a real podman container: both sockets come up
# correctly, dispatch.sock structurally cannot reach launch/kill/list/attach
# (UNKNOWN_METHOD), and non-dispatchable rooms are refused. That part of
# "not ready to run" is resolved.
#
# What's STILL open, found by testing it for real rather than guessing:
# mounting the host's rootless podman API socket into this container
# (the CONTAINER_HOST approach below) reaches the socket (no ENOENT) but
# gets a flat permission denial connecting to it — tried matching
# --user to the socket's owning uid:gid, and --userns=keep-id, neither
# resolved it (rootless-podman-in-rootless-podman user-namespace/SELinux
# interaction, not a simple ownership fix). Disabling SELinux confinement
# on the mount was NOT attempted as a fix here — that's a real security
# posture change, not a config detail, and deserves a deliberate decision
# by someone who owns that tradeoff, not a quick unblock. Until this is
# resolved, launcherd can run (and dispatch's socket-isolation guarantees
# hold), but it cannot actually EXECUTE a spawn that reaches this host's
# real podman.
#
# Boxes ask to spawn/inspect/kill sub-boxes through /run/doors/launcherd.sock
# (the --launcher door, attenuated, name-based identity — see LAUNCHERD.md),
# or request an independent task session through /run/doors/dispatch.sock
# (the --dispatch door, doors-blind, allow-listed rooms only — see
# launcherd.ts's DISPATCH_METHODS / handleDispatch). launcherd owns the
# runtime for BOTH lanes; boxes never hold podman.
#
# Install:
#   cp *.volume *.container ~/.config/containers/systemd/
#   systemctl --user daemon-reload
#   systemctl --user enable --now launcherd
#
# Logs:
#   journalctl --user -u launcherd -f

[Unit]
Description=launcherd — launch-controller daemon for claude-box (launch + dispatch)
After=claude-doors-volume.service

[Container]
Image=localhost/launcherd:dev
ContainerName=launcherd

# Same numeric uid/gid as every other socket-creating door daemon — see
# keeperd.container's comment for why (shared doors dir, no world-writable).
# Confirmed live: without this, launcherd's OWN assertSocketDir check
# correctly refuses to start ("refusing socket in world-writable /run/doors
# (hijack risk)") rather than silently trusting a directory anyone can write
# to — this UserNS line is the actual fix, not a reason to relax that check.
UserNS=keep-id:uid=1000,gid=1000

# Socket directory — same shared volume every other door uses. launcherd
# listens on BOTH launcherd.sock (general) and dispatch.sock (narrow) here —
# see launcherd.ts's serve(socketPath, dispatchSocketPath).
Volume=%h/.claude-box/run:/run/doors

# launcherd is the one daemon that must reach the HOST's container runtime
# (to actually spawn/inspect/kill sibling containers) — unlike keeperd/netd/
# scoutd, which are pure socket daemons with no host-control surface at all.
# This mount REACHES the socket but currently gets permission-denied talking
# to it (see the [Unit] comment above for what was tried) — left in place as
# the intended shape, not because it's known to work yet.
#   Volume=%t/podman/podman.sock:/run/podman/podman.sock
#   Environment=CONTAINER_HOST=unix:///run/podman/podman.sock
# This is a meaningfully more privileged grant than anything keeperd/netd/
# scoutd need (it's adjacent to "control the host's container runtime") —
# resolving the permission denial (matching uid/gid alone and --userns=
# keep-id both failed in testing) needs someone who owns the security
# tradeoff to decide the approach — e.g. a narrower proxy in front of the
# socket, a dedicated rootless podman user the launcherd container's
# namespace genuinely maps to, or another mechanism entirely — not a
# quick unblock.
Volume=%t/podman/podman.sock:/run/podman/podman.sock
Environment=CONTAINER_HOST=unix:///run/podman/podman.sock

# Security hardening — same floor as the other doors. NoNewPrivileges/
# DropCapability=all/ReadOnly still apply to launcherd's OWN process; they do
# NOT reduce what the mounted podman socket itself can do once reached (see
# the note above).
NoNewPrivileges=true
ReadOnly=true
ReadOnlyTmpfs=true
DropCapability=all
SecurityLabelDisable=true

# Resource limits
PidsLimit=256
Memory=512m

[Service]
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
